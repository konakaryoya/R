{
  "name": "R-devtool-Env",
  "dockerComposeFile": "docker-compose.yml",
  "service": "r-dev-env",
  "workspaceFolder": "/home/rstudio/project",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {}
  },
  "forwardPorts": [8787],
  "customizations": {
    "vscode": {
      "settings": {
        "r.bracketedPaste": true
      },
      "extensions": [
        "REditorSupport.r",
        "REditorSupport.r-syntax",
        "dbcode.dbcode",
        "yzhang.markdown-all-in-one"
      ]
    }
  }
}
